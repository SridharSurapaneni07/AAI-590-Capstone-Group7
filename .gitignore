# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# PyInstaller / Distribution
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg

# MacOS File System
.DS_Store

# IDEs
.idea/
.vscode/
*.swp
*.swo

# Project Specific Data & Heavy Files
# We ignore the heavy Kaggle CSVs and raw images, teammates must download them locally
# data/raw/
# data/processed/
*.csv
*.json
*.jpg
*.jpeg
*.png

# Allow specific data files
!data/**/*.csv
!data/**/*.json

# Explicitly ignore REI-Dataset images
data/raw/REI-Dataset/**/*.jpg
data/raw/REI-Dataset/**/*.jpeg
data/raw/REI-Dataset/**/*.png

# Allow the default Streamlit assets to be committed
!app/assets/*.png
!reports/figures/*.png

# Model Weights (Do not push 500MB PyTorch files to GitHub)
models/vision/*.pth
models/baselines/*.json
*.pt
*.bin
*.ptc

# Jupyter Notebook Checkpoints
.ipynb_checkpoints

# Logs
*.log
logs/

# MLflow runs (too many files, keep local only)
mlruns/
mlruns.db

# Database files
*.db
!optuna_study.db
